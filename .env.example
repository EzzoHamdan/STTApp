# Court STT — Azure Speech credentials
# Copy this file to .env and fill in your values.

# ── Azure Speech Service credentials (REQUIRED) ──────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=uaenorth
AZURE_SPEECH_LANGUAGE=ar-JO

# ── Audio settings (optional — defaults are fine for most cases) ─────────
# AUDIO_SAMPLE_RATE=16000
# AUDIO_CHANNELS=1
# AUDIO_BLOCK_SIZE=1024

# ── Server settings (optional) ───────────────────────────────────────────
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

# ── File paths (optional — relative to project root) ─────────────────────
# SESSIONS_DIR=sessions
# STATIC_DIR=court_stt/static

# ── Logging ──────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Default speakers (comma-separated) ───────────────────────────────────
# DEFAULT_SPEAKERS=Judge,Lawyer_1,Lawyer_2
