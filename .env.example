# ============================================
# Arabic STT Platform — Configuration
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# ── Arena Providers ──────────────────────────────────────────────
# Deepgram Nova-3 (https://console.deepgram.com)
DEEPGRAM_API_KEY=your_deepgram_key_here

# Munsit by CNTXT AI (https://munsit.com · API portal: https://app.cntxt.tools)
MUNSIT_API_KEY=your_munsit_key_here

# Soniox (https://soniox.com)
SONIOX_API_KEY=your_soniox_key_here

# Speechmatics (https://portal.speechmatics.com)
SPEECHMATICS_API_KEY=your_speechmatics_key_here

# ── Court Transcription (Azure Speech) ──────────────────────────
# Azure Speech-to-Text (https://portal.azure.com)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_LANGUAGE=ar-JO

# ── Server ───────────────────────────────────────────────────────
PORT=3001

# ── Access Restriction (optional) ────────────────────────────────
# Set a code to require authentication before using the platform.
# Leave empty or unset to allow open access.
# ACCESS_CODE=your_secret_code_here

# ── Production (optional) ────────────────────────────────────────
# NODE_ENV=production
# CORS_ORIGINS=https://your-domain.com,https://other-domain.com
