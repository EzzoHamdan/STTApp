# ============================================
# Arabic STT Arena — Centralized API Keys
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Restart the server after editing.

# Deepgram Nova-3 (https://console.deepgram.com)
DEEPGRAM_API_KEY=your_deepgram_key_here

# Munsit by CNTXT AI (https://munsit.com · API portal: https://app.cntxt.tools)
# Sign up at app.cntxt.tools or contact munsit@cntxt.tech for API access
# Docs: https://munsit.com/munsit/api-docs
MUNSIT_API_KEY=your_munsit_key_here
# Override endpoint (default: https://api.cntxt.tools)
# MUNSIT_WS_URL=https://api.cntxt.tools

# Soniox (https://soniox.com)
SONIOX_API_KEY=your_soniox_key_here

# Speechmatics (https://portal.speechmatics.com)
SPEECHMATICS_API_KEY=your_speechmatics_key_here

# ── Court Transcription (Azure Speech) ──────────────────────
# Azure Speech-to-Text (https://portal.azure.com → Cognitive Services)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_LANGUAGE=ar-JO

# Server port (default: 3001)
PORT=3001
